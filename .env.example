# ===========================================
# Cortex Clinical Affairs - Environment Variables
# ===========================================

# Application
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# Database (PostgreSQL)
DATABASE_URL=postgresql://cortex:cortex_secret@localhost:5432/cortex_dev
POSTGRES_DB=cortex_dev
POSTGRES_USER=cortex
POSTGRES_PASSWORD=cortex_secret

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://cortex:cortex_secret@localhost:5672
RABBITMQ_USER=cortex
RABBITMQ_PASSWORD=cortex_secret

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=cortex_minio
MINIO_SECRET_KEY=cortex_minio_secret
MINIO_USE_SSL=false
MINIO_BUCKET=cortex-documents

# Authentication
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production-refresh
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# OAuth (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# AI / LLM Providers
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# External APIs
PUBMED_API_KEY=
GROBID_URL=http://localhost:8070

# Email / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@cortex.local
